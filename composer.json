{
    "name": "divineapi/divineapi",
    "description": "Official PHP SDK for Divine API - Astrology, Horoscope, Numerology, Tarot, and more",
    "type": "library",
    "license": "MIT",
    "keywords": ["divineapi", "astrology", "horoscope", "numerology", "tarot", "kundli", "panchang"],
    "homepage": "https://divineapi.com",
    "authors": [
        {
            "name": "Divine API",
            "email": "support@divineapi.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "DivineApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DivineApi\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/DivineAPI/divineapi-php/issues",
        "source": "https://github.com/DivineAPI/divineapi-php"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
